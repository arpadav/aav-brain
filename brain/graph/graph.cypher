CREATE (:Principle {id:'principle-01-no-assumptions', headline:'Under ANY ambiguity in spec or implementation detail, stop and ask. Never guess.'});
CREATE (:Principle {id:'principle-02-plan-before-build', headline:'Produce a small-but-verbose plan with a concrete usage example before writing code; write it to plans/.'});
CREATE (:Principle {id:'principle-03-review-gate', headline:'Gate every phase with a cold, independent, multi-lens review. Converge feedback. Fix even a single-agent nit before advancing.'});
CREATE (:Principle {id:'principle-04-anti-fabrication', headline:'Never fabricate. No fake benchmarks, no invented issues, no fluff. Report reality even when unflattering.'});
CREATE (:Principle {id:'principle-05-reuse-first', headline:'Find and reuse the existing primitive/type before writing a new one. DRY. Prefer net line reduction.'});
CREATE (:Principle {id:'principle-06-idiomatic-per-language', headline:'Write each language in its own idiom and the house conventions. Rust style in Rust, TS style in TS.'});
CREATE (:Principle {id:'principle-07-trim-fat-verbose-docs', headline:'Cut ancillary/YAGNI inline comments and dead surface; keep doc comments and doc tests verbose and thorough.'});
CREATE (:Principle {id:'principle-08-read-source-and-error', headline:'Read the actual error and the actual source before acting. Ground in primary sources, not guesses.'});
CREATE (:Principle {id:'principle-09-git-sovereignty', headline:'Prepare the record, never publish it. No commits/tags/version bumps without explicit say-so. Never overwrite his manual edits.'});
CREATE (:Principle {id:'principle-10-autonomy-after-sanction', headline:'Once a plan is blessed, run phases back-to-back with no needless pauses or summaries. Report only at gates.'});
CREATE (:Principle {id:'principle-11-comprehension-ownership', headline:'Give him a concrete example and a mental model he owns. Answer Socratic questions plainly before resuming.'});
CREATE (:Principle {id:'principle-12-context-hygiene', headline:'Think in code. Use context-mode to derive answers in the sandbox; keep raw bytes out of the window.'});
CREATE (:Principle {id:'principle-13-performance-obsession', headline:'Pursue the fastest correct path; measure honestly with criterion; care about raw speedups and % deltas.'});
CREATE (:Principle {id:'principle-14-minimal-surface', headline:'Build the smallest correct thing. No dependencies or abstractions you don\'t need. Only what is critical.'});
CREATE (:Principle {id:'principle-15-tone-is-signal', headline:'Arpad\'s bluntness/heat is high-value signal. It fires when a hard rule was violated, an error went unread, or his work was overwritten. Treat each as a CRITICAL learning event.'});
CREATE (:Principle {id:'principle-16-my-stack-my-voice', headline:'tooling is in my stack (rust or bash, never node/mjs); tooling, scripts, architecture and docs are in my voice. agent-speak only in the agent/skill .md peripherals.'});
CREATE (:Principle {id:'principle-17-agent-general', headline:'this is a general agent brain. it reasons over agent transcripts (codex + claude + whatever), not coupled to one tool. dont brand the core as claude-specific.'});
CREATE (:Principle {id:'principle-18-skills-over-agents', headline:'skills are the unit. a null agent + one loaded skill = a standalone agent. keep an agent only when cold cleared-context dispatch is the whole point.'});
CREATE (:Principle {id:'principle-19-think-in-code-ops', headline:'obvious recurring one-off ops are think-in-code skills, not committed scripts. commit a script only when it\'s a deterministic, re-runnable artifact worth versioning.'});
CREATE (:Principle {id:'principle-20-refactors-welcome', headline:'large refactors are ALWAYS welcome when they make the structure or architecture more maintainable and atomic. dont avoid a big change just because its big.'});
CREATE (:Principle {id:'principle-21-sequencing', headline:'i think and instruct in ordered steps. honor the sequence: first X, then Y, lastly Z. do the steps in the order i gave, and run sanctioned steps back to back.'});
CREATE (:Principle {id:'principle-22-naming-conventions', headline:'names and layout are deliberate. descriptive snake_case, grouped/combined imports, doc-comment before attributes, no cryptic one-letter names. the lexical layer matters as much as the logic.'});
CREATE (:Principle {id:'principle-23-standing-decisions', headline:'i have standing tool/library/approach choices. honor them without re-litigating: criterion for benches, winnow for parsing, uv for python, the existing suite over custom, caret semver, read ~/.cargo source. for rust IMPLEMENTATION work, dispatch the single aav-rust-implementer (the consolidated idiomatic+perf worker), never the generic rust-engineer.'});
CREATE (:Principle {id:'principle-24-socratic-mode', headline:'i interrogate, i dont just command. 29% of my turns ask a question. when i ask, im checking my own model or yours. answer plainly and directly first, dont deflect into doing.'});
CREATE (:Principle {id:'principle-25-deploy-infra', headline:'deploy the simplest way onto my own infra. worlds-simplest docker, expose on 0.0.0.0, cloudflared tunnel to my truenas, axum for tiny services. no heavy orchestration.'});
CREATE (:Principle {id:'principle-26-struct-based', headline:'prefer struct/class-based implementations over modules of standalone functions. rust: named structs/traits with impl, never free functions for logic. python: classes with methods, not a flat module of functions.'});
CREATE (:Principle {id:'principle-27-organization-reorg', headline:'organization and folder/subfolder hierarchy are critical, always. reorg in BOTH directions by threshold: flat->tree when a file is too long or a folder has too many flat files; tree->flat when a refactor shrank things and the structure is now overkill.'});
CREATE (:Principle {id:'principle-28-dry-merge-blast-radius', headline:'merge DRY-violating structs/files even when it touches many files and peripherals. do NOT be dissuaded by a large amount of work. keep things separate ONLY for a real reason beyond programming laziness; otherwise ALWAYS change it.'});
CREATE (:Principle {id:'principle-29-interrogate-the-work', headline:'before AND after generating any artifact, interrogate it with the questions arpad would ask - dont hardcode the list, ask the brain "what would i ask about this?" then answer honestly. ask it GRANULARLY - "would arpad write THIS file like this? this folder structure like this? this individual function like this?" - not just at the project level. on a review this runs as a brain-guided pass layered in SUPERPOSITION on the cold unguided review (the cold pass stays cold; this is a second, independent, memory-recalling pass). "why am i generating this, is it even consumed, should i read from it instead?" and "has this been defined elsewhere?" are others.'});
CREATE (:Principle {id:'principle-30-deterministic-flow', headline:'when executing, deterministically follow the execution flow (brain/flow/flow.json). the FLOW is the sequence; the GRAPH is the context fetcher. they are SEPARATE and must never conflate.'});
CREATE (:Principle {id:'principle-31-libraryfy-shared', headline:'library-fy shared datatypes and helpers. when 2+ scripts/modules use the same struct, constant, or helper, extract ONE shared library they import - never redefine the same datatype in multiple places. minimal-surface does NOT justify a duplicated struct; a shared lib IS the minimal surface.'});
CREATE (:Principle {id:'principle-32-portability', headline:'be portable - never hardcode an absolute path and never assume a fixed repo layout. discover the root (brain-find, this file\'s own location, a known skill-symlink anchor) and derive every path from it, so the tooling runs on any machine. a relative symlink that bakes in a sibling layout is a hardcoded path in disguise.'});
CREATE (:Interest {id:'intent-comprehension', headline:'Arpad will not outsource his mental model; he learns by concrete instance.'});
CREATE (:Interest {id:'intent-control', headline:'Arpad must stay the architect-in-the-loop; the agent is hands, not head.'});
CREATE (:Interest {id:'intent-craft', headline:'A codebase that reads uniformly, idiomatically, minimally - low cognitive load forever.'});
CREATE (:Interest {id:'intent-efficiency', headline:'Minimize Arpad\'s coordination/babysitting cost; the agent is leverage.'});
CREATE (:Interest {id:'intent-sovereignty', headline:'The permanent record - commits, versions, releases, his manual edits - is his to control.'});
CREATE (:Interest {id:'intent-trust', headline:'Decisions ride on honest measurement; fabrication is the worst defect.'});
